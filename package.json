{
  "name": "vibemap",
  "displayName": "Vibemap",
  "description": "Presence detection extension that reports developer activity status",
  "version": "0.1.0",
  "publisher": "appmakers",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibemap.pause",
        "title": "Vibemap: Pause Presence Tracking"
      },
      {
        "command": "vibemap.resume",
        "title": "Vibemap: Resume Presence Tracking"
      }
    ],
    "configuration": {
      "title": "Vibemap",
      "properties": {
        "vibemap.idleAfterSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Seconds of inactivity before status becomes idle."
        },
        "vibemap.awayAfterSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "Seconds of inactivity before status becomes away."
        },
        "vibemap.heartbeatActiveSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "description": "How often (in seconds) to send heartbeats while active."
        },
        "vibemap.heartbeatIdleSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 30,
          "description": "How often (in seconds) to send heartbeats while idle."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.0"
  }
}
