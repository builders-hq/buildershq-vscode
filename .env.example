# BuildersHQ optional environment configuration
#
# Point buildershq.sharedEnvFilePath at a copy of this file (with real values)
# to enable GitHub device-flow login and MongoDB persistence.
# None of these are required — the extension works without them.

# Override the presence API endpoint (takes precedence over buildershq.serverUrl setting)
# PRESENCE_SERVER_URL=http://127.0.0.1:3000/api/presence

# GitHub OAuth app credentials for device-flow login fallback.
# Create an OAuth App at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# MongoDB connection URI for persisting heartbeat data server-side (optional)
# MONGODB_URI=mongodb://localhost:27017
